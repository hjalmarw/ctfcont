# Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Anthropic API base URL (e.g. for proxies or local models)
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Read-only source directory — the code Claude will analyse
SOURCE_DIR=/path/to/ctf/challenge

# Writable output directory — Claude writes patches, diffs, findings here
OUTPUT_DIR=/path/to/output
